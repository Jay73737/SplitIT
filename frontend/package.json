{
  "name": "stem-splitter-ui",
  "version": "0.1.0",
  "private": true,
  "main": "electron.js",
  "dependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^13.5.0",
    "@wavesurfer/react": "^1.0.11",
    "framer-motion": "^11.18.2",
    "node-fetch": "^2.7.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-scripts": "5.0.1",
    "wavesurfer.js": "^7.10.1",
    "web-vitals": "^2.1.4",
    "ytdl-core": "^4.11.5",
    "zustand": "^5.0.7"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "electron": "env -u ELECTRON_RUN_AS_NODE electron .",
    "electron-dev": "concurrently \"npm start\" \"wait-on http://localhost:3000 && env -u ELECTRON_RUN_AS_NODE ELECTRON_START_URL=http://localhost:3000 electron .\"",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "concurrently": "^9.2.0",
    "cross-env": "^10.0.0",
    "electron": "^37.2.5",
    "electron-builder": "^24.13.3",
    "wait-on": "^8.0.4"
  },
  "build": {
    "appId": "com.splitme.desktop",
    "productName": "SplitMe",
    "directories": {
      "buildResources": "buildResources",
      "output": "../release"
    },
    "files": [
      "build/**/*",
      "electron.js",
      "preload.js",
      "pill-preload.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../dist/backend/SplitMeBackend",
        "to": "backend"
      }
    ],
    "mac": {
      "category": "public.app-category.music",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "buildResources/icon.png"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        "zip"
      ],
      "icon": "buildResources/icon.png"
    },
    "linux": {
      "target": [
        "AppImage",
        "tar.gz"
      ],
      "category": "AudioVideo",
      "icon": "buildResources/icon.png"
    }
  }
}
